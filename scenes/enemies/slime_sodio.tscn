[sub_resource type="Shader" id="Shader_s7h58"]
code = "shader_type canvas_item;

void fragment() {
	vec4 col = texture(TEXTURE, UV);
	// Remove fundo marrom escuro: pixels com baixa saturação laranja e baixo brilho
	float is_orange = step(0.3, col.r - col.b);   // laranja = R muito maior que B
	float is_bright = step(0.15, col.r);           // descarta pixels muito escuros
	float keep = clamp(is_orange + (1.0 - is_bright) * 0.0, 0.0, 1.0);
	// Pixels que não são laranjas E são escuros = fundo → transparente
	float bg = (1.0 - is_orange) * step(col.r, 0.35);
	COLOR = vec4(col.rgb, col.a * (1.0 - bg));
}
"

